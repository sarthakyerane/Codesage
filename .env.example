# MySQL
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DATABASE=codesage
MYSQL_USER=codesage_user
MYSQL_PASSWORD=codesage_pass

# Ollama (used for embeddings — runs on your host machine)
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_EMBED_MODEL=nomic-embed-text

# OpenAI (optional — leave blank to skip)
OPENAI_API_KEY=

# Groq (free, fast LLM — sign up at console.groq.com)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# ChromaDB
CHROMA_PERSIST_DIR=/app/chroma_db

# Redis
REDIS_URL=redis://redis:6379

# App
APP_ENV=development
LOG_LEVEL=INFO
